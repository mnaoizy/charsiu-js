{
  "name": "charsiu-js",
  "version": "0.1.0",
  "description": "Neural phonetic forced aligner (wav2vec2) for Node and the browser — a JS port of charsiu. Aligns audio to a transcript at the phone and word level, fully client-side.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "homepage": "https://github.com/lingjzhu/charsiu",
  "keywords": [
    "forced-alignment",
    "phonetic",
    "wav2vec2",
    "speech",
    "g2p",
    "phoneme",
    "alignment",
    "onnx",
    "onnxruntime",
    "transformers",
    "charsiu",
    "textgrid"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "node": {
        "types": "./dist/aligner-node.d.ts",
        "default": "./dist/aligner-node.js"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./core": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/aligner-node.d.ts",
      "default": "./dist/aligner-node.js"
    },
    "./assets-node": {
      "types": "./dist/assets-node.d.ts",
      "default": "./dist/assets-node.js"
    },
    "./assets-web": {
      "types": "./dist/assets-web.d.ts",
      "default": "./dist/assets-web.js"
    }
  },
  "files": [
    "dist/",
    "src/",
    "assets/",
    "README.md",
    "ATTRIBUTION.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "onnxruntime-node": ">=1.20.0",
    "onnxruntime-web": ">=1.20.0"
  },
  "peerDependenciesMeta": {
    "onnxruntime-node": {
      "optional": true
    },
    "onnxruntime-web": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "onnxruntime-node": "^1.26.0",
    "onnxruntime-web": "^1.26.0",
    "playwright": "^1.60.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "convert": "python scripts/convert.py",
    "quantize": "python scripts/quantize.py",
    "export-g2p": "python scripts/export_g2p.py",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:onnx": "node test/run-onnx.mjs",
    "test:align": "node test/run-align.mjs",
    "test:g2p": "node test/run-g2p.mjs",
    "test:g2pm": "node test/run-g2pm.mjs",
    "test:standalone": "node test/run-standalone.mjs",
    "test:standalone-zh": "node test/run-standalone-zh.mjs",
    "test:browser": "node test/run-browser.mjs",
    "test": "npm run test:onnx && npm run test:g2p && npm run test:g2pm && npm run test:standalone && npm run test:standalone-zh && npm run test:browser && tsc -p tsconfig.test.json",
    "serve": "node test/serve.mjs",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "pretest": "npm run build"
  }
}